---
const {
  title,
  subtitle,
  price,
  priceLabel,
  recurring,
  features,
  buttonText,
  buttonHref,
  featured = false,
} = Astro.props as {
  title: string;
  subtitle: string;
  price: string;
  priceLabel: string;
  recurring: string;
  features: string[];
  buttonText: string;
  buttonHref: string;
  featured?: boolean;
};

const cardClass = featured
  ? "fade-in group relative p-8 rounded-2xl bg-linear-to-br from-indigo-500/10 to-cyan-500/10 backdrop-blur-md border-2 border-indigo-500/40 shadow-xl shadow-indigo-500/10 md:scale-105 hover:border-indigo-400/60 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl hover:shadow-indigo-500/20"
  : "fade-in group relative p-8 rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 hover:border-white/20 transition-all duration-300 hover:-translate-y-1";

const buttonClass = featured
  ? "block w-full text-center px-6 py-3 rounded-xl bg-linear-to-r from-indigo-500 to-cyan-400 text-white font-semibold hover:shadow-lg hover:shadow-indigo-500/25 transition-all hover:-translate-y-0.5"
  : "block w-full text-center px-6 py-3 rounded-xl border border-white/20 text-white font-semibold hover:bg-white/5 hover:border-white/30 transition-all hover:-translate-y-0.5";
---

<div class={cardClass}>
  {featured ? (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2">
      <span class="px-4 py-1.5 rounded-full bg-linear-to-r from-indigo-500 to-cyan-400 text-white text-xs font-bold uppercase tracking-wider shadow-lg">
        Más elegido
      </span>
    </div>
  ) : null}

  <div class={featured ? "mb-6 mt-2" : "mb-6"}>
    <h3 class="text-white font-bold text-xl mb-2">{title}</h3>
    <p class="text-white/50 text-sm">{subtitle}</p>
  </div>

  <div class="mb-8">
    <span class={featured ? "text-4xl font-bold bg-linear-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent" : "text-4xl font-bold text-white"}>{price}</span>
    <span class="text-white/50 text-sm">{priceLabel}</span>
    <div class="text-gray-400 text-sm">{recurring}</div>
  </div>

  <ul class="space-y-4 mb-8">
    {features.map((feature) => (
      <li class="flex items-start gap-3">
        <svg class="w-5 h-5 text-indigo-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span class="text-white/70 text-sm">{feature}</span>
      </li>
    ))}
  </ul>

  <a href={buttonHref} class={buttonClass}>
    {buttonText}
  </a>
</div>
