---
import PricingCard from "./PricingCard.astro";

const plans = [
  {
    title: "Stock",
    subtitle: "Controla tu stock con solo un mensaje",
    price: "$449",
    priceLabel: "primer pago",
    recurring: "+ $100 por mes",
    features: [
      "Actualiza tus ventas y stock con un simple mensaje",
      "Generación de reportes de ventas y metricas",
      "Soporte para whatsapp, telegram y email",
      "Reporte mensual",
      "A medida de tus necesidades",
    ],
    buttonText: "Empezar ahora",
    buttonHref: "#contacto",
    featured: false,
  },
  {
    title: "Crecimiento",
    subtitle: "El sistema completo de ventas",
    price: "$597",
    priceLabel: "primer pago",
    recurring: "+ $597 por mes",
    features: [
      "Web profesional optimizada para convertir clientes",
      "Agente de IA 24/7",
      "3 campañas de Meta Ads",
      "Publicación automática de contenido",
      "Bot de ventas con agendamiento",
      "Gestión básica de stock",
      "Dashboard de métricas en vivo",
    ],
    buttonText: "Quiero este plan",
    buttonHref: "#contacto",
    featured: true,
  },
  {
    title: "Escala",
    subtitle: "Máxima automatización",
    price: "$997",
    priceLabel: "primer pago",
    recurring: "+ $997 por mes",
    features: [
      "Todo lo del plan Crecimiento",
      "Múltiples agentes de IA",
      "Campañas ilimitadas",
      "Gestión inteligente de stock con IA",
      "CRM personalizado a medida",
      "Chatbots internos para tu equipo",
      "Manager dedicado + llamadas semanales",
    ],
    buttonText: "Contactar ventas",
    buttonHref: "#contacto",
    featured: false,
  },
];
---

<section id="pricing" class="relative py-30 px-6 bg-gray-950 overflow-hidden">
  
  <div class="absolute inset-0 bg-radial from-indigo-500/8 at center to-transparent"></div>
  
  <div class="relative z-10 max-w-6xl mx-auto">
    
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-sm text-indigo-400 font-semibold mb-4">
        Planes
      </span>
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
        Elegí el plan para tu <span class="bg-linear-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent">crecimiento</span>
      </h2>
      <p class="text-white/60 max-w-xl mx-auto text-lg">
        Todos incluyen implementación, soporte y actualizaciones. Sin costos ocultos.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 items-start">
      {plans.map((plan) => (
        <PricingCard {...plan} />
      ))}
    </div>

  </div>

</section>

<style>
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease forwards;
  }
  .fade-in:nth-child(1) { animation-delay: 0.1s; }
  .fade-in:nth-child(2) { animation-delay: 0.2s; }
  .fade-in:nth-child(3) { animation-delay: 0.3s; }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
