<section id="contacto" class="relative py-24 px-6 bg-gray-950 overflow-hidden">
  
  <div class="absolute inset-0 bg-radial from-indigo-500/5 at center to-transparent"></div>
  
  <div class="relative z-10 max-w-5xl mx-auto">
    
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-sm text-indigo-400 font-semibold mb-4">
        Contacto
      </span>
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
        Hablemos de tu <span class="bg-linear-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent">negocio</span>
      </h2>
      <p class="text-white/60 max-w-xl mx-auto text-lg">
        Escribinos y te respondemos en menos de 2 horas. Sin compromiso.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      
      <div class="fade-in">
        <div class="p-8 rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 h-full">
          <h3 class="text-white font-bold text-xl mb-6">Escribinos directo</h3>
          
          <div class="space-y-6">
            <a href="#" class="flex items-center gap-4 group">
              <div class="w-12 h-12 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center group-hover:border-green-500/40 transition-all">
                <svg class="w-6 h-6 text-green-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.34 0-4.508-.784-6.244-2.1l-.144-.112-3.286 1.102 1.102-3.286-.112-.144A9.935 9.935 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/>
                </svg>
              </div>
              <div>
                <p class="text-white font-semibold">WhatsApp</p>
                <p class="text-white/50 text-sm">+54 9 11 1234-5678</p>
              </div>
            </a>

            <a href="mailto:hola@elevate.com" class="flex items-center gap-4 group">
              <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center group-hover:border-indigo-500/40 transition-all">
                <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-white font-semibold">Email</p>
                <p class="text-white/50 text-sm">hola@elevate.com</p>
              </div>
            </a>

            <a href="#" class="flex items-center gap-4 group">
              <div class="w-12 h-12 rounded-xl bg-pink-500/10 border border-pink-500/20 flex items-center justify-center group-hover:border-pink-500/40 transition-all">
                <svg class="w-6 h-6 text-pink-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </div>
              <div>
                <p class="text-white font-semibold">Instagram</p>
                <p class="text-white/50 text-sm">@elevate</p>
              </div>
            </a>
          </div>

          <div class="mt-8 p-4 rounded-xl bg-white/5 border border-white/10">
            <p class="text-white/60 text-sm">
              <span class="text-green-400 font-semibold">Respuesta rápida:</span> normalmente contestamos en menos de 2 horas. Y sí, irónico que una agencia de automatización responda rápido a mano.
            </p>
          </div>
        </div>
      </div>

      <div class="fade-in">
        <form class="p-8 rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 h-full space-y-6">
          <div>
            <label for="name" class="block text-white/70 text-sm font-medium mb-2">Nombre</label>
            <input type="text" id="name" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-white/30 focus:outline-none focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/25 transition-all" placeholder="Tu nombre">
          </div>
          <div>
            <label for="email" class="block text-white/70 text-sm font-medium mb-2">Email</label>
            <input type="email" id="email" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-white/30 focus:outline-none focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/25 transition-all" placeholder="tu@email.com">
          </div>
          <div>
            <label for="message" class="block text-white/70 text-sm font-medium mb-2">¿Qué necesitás?</label>
            <textarea id="message" rows="4" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-white/30 focus:outline-none focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/25 transition-all resize-none" placeholder="Contanos sobre tu negocio y qué querés automatizar..."></textarea>
          </div>
          <button type="submit" class="w-full px-6 py-3 rounded-xl bg-linear-to-r from-indigo-500 to-cyan-400 text-white font-bold hover:shadow-lg hover:shadow-indigo-500/25 transition-all hover:-translate-y-0.5">
            Enviar mensaje
          </button>
        </form>
      </div>

    </div>

  </div>

</section>
